generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  channelIdentities ChannelIdentity[]
  driveConnections  DriveConnection[]
  messages          Message[]

  @@map("users")
}

model ChannelIdentity {
  id         String   @id @default(uuid())
  userId     String?
  platform   String
  externalId String
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  messages Message[]

  @@unique([platform, externalId])
  @@index([userId])
  @@map("channel_identities")
}
model DriveConnection {
  id                String    @id @default(uuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String
  refreshToken      String
  expiry            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("drive_connections")
}

model Attachment {
  id String @id @default(uuid())

  messageId String

  platformFileId String? // telegram file_id / whatsapp media id
  fileName       String?
  mimeType       String?
  fileSize       Int?

  localUrl String? // later: S3 or storage path

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("attachments")
}

model Message {
  id String @id @default(uuid())

  userId            String?
  channelIdentityId String?

  platform  String
  direction String
  type      String

  externalUserId    String?
  externalChatId    String?
  externalMessageId String?

  textContent String?
  rawPayload  Json

  status String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  channelIdentity ChannelIdentity? @relation(fields: [channelIdentityId], references: [id], onDelete: SetNull)

  attachments Attachment[]

  @@index([userId])
  @@index([channelIdentityId])
  @@index([platform, externalUserId])
  @@map("messages")
}
